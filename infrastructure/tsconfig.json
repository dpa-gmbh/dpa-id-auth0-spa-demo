{
  "compilerOptions": {
    "target": "ES2025",
    "module": "NodeNext",
    "lib": ["ES2025"],
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "types": ["node"]
  },
  "exclude": ["node_modules", "cdk.out"]
}
